<?xml version="1.0" encoding="utf-8"?>
<!-- 2x2 grid art form card — fixed square tile -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:layout_margin="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/background_card">

    <!-- Real art form content -->
    <LinearLayout
        android:id="@+id/layoutReal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/bg_card_gradient">

        <!-- Emoji circle -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_notification_badge"
            android:layout_gravity="center_horizontal">
            <TextView
                android:id="@+id/tvGridEmoji"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🥁"
                android:textSize="24sp" />
        </FrameLayout>

        <!-- Name -->
        <TextView
            android:id="@+id/tvGridName"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Dollu Kunitha"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:layout_marginTop="8dp" />

        <!-- District -->
        <TextView
            android:id="@+id/tvGridDistrict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Mysuru"
            android:textColor="@color/accent"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Book + Call row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGridBook"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="📅"
                android:textSize="16sp"
                android:background="@drawable/bg_button_gold"
                android:stateListAnimator="@null"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnGridCall"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="📞"
                android:textSize="16sp"
                android:textColor="@color/accent"
                style="@style/KBButton.Outlined"
                android:stateListAnimator="@null"
                android:padding="0dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Placeholder content (shown when no art form) -->
    <LinearLayout
        android:id="@+id/layoutPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="14dp"
        android:background="@color/background_surface"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎪"
            android:textSize="30sp"
            android:alpha="0.4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coming Soon"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:textStyle="italic"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="More artists\nbeing added"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:alpha="0.6" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
