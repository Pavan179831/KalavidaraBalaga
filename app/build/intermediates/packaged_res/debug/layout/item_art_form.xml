<?xml version="1.0" encoding="utf-8"?>
<!-- Art form card with View Profile + Book + Call -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/background_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Art form icon + name row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <!-- Emoji circle -->
            <FrameLayout
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_card_gradient"
                android:layout_marginEnd="14dp">
                <TextView
                    android:id="@+id/tvArtEmoji"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🥁"
                    android:textSize="26sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Bold title -->
                <TextView
                    android:id="@+id/tvArtFormName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dollu Kunitha"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- District — regular weight -->
                <TextView
                    android:id="@+id/tvDistrictBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Mysuru"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

                <!-- Phone — accent color -->
                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 +91 XXXXXXXXXX"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="12dp" />

        <!-- View Profile — full width outlined -->
        <Button
            android:id="@+id/btnViewProfile"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginBottom="10dp"
            android:text="👁  View Full Profile"
            android:textColor="@color/accent"
            android:textSize="13sp"
            style="@style/KBButton.Outlined"
            android:stateListAnimator="@null" />

        <!-- Book + Call side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- PRIMARY: Book (gold, bold) -->
            <Button
                android:id="@+id/btnBook"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📅 Book Now"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="13sp"
                android:background="@drawable/bg_button_gold"
                android:stateListAnimator="@null" />

            <!-- SECONDARY: Call (outlined) -->
            <Button
                android:id="@+id/btnCall"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="📞 Call"
                android:textColor="@color/accent"
                android:textSize="13sp"
                style="@style/KBButton.Outlined"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
