<?xml version="1.0" encoding="utf-8"?>
<!-- Upcoming booking card -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/background_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Left date block -->
        <LinearLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_gradient"
            android:layout_marginEnd="14dp">

            <TextView
                android:id="@+id/tvDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textColor="@color/accent"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAY"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <!-- Booking info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Art form name — bold title -->
            <TextView
                android:id="@+id/tvBookingArtForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dollu Kunitha"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Event name — regular -->
            <TextView
                android:id="@+id/tvBookingEvent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Wedding Ceremony"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="3dp" />

            <!-- Location -->
            <TextView
                android:id="@+id/tvBookingLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📍 Mysuru"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <!-- Status badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_art_type_badge"
                android:text="✅ Confirmed"
                android:textColor="@color/badge_green"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Edit arrow -->
        <TextView
            android:id="@+id/tvEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️"
            android:textSize="18sp"
            android:padding="8dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
