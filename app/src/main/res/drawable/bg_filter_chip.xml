<?xml version="1.0" encoding="utf-8"?>
<!--
    Selector drawable for art form chip background:
    - Selected state: gold border + gold tint
    - Default state: subtle border
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#33D4A017" />
            <stroke android:color="#D4A017" android:width="1.5dp" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#55D4A017" />
            <stroke android:color="#D4A017" android:width="1.5dp" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1AD4A017" />
            <stroke android:color="#5C2020" android:width="1dp" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</selector>
