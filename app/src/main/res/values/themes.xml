<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════
         BASE APP THEME
    ══════════════════════════════════════════ -->
    <style name="Theme.KalavidaraBalaga" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Consistent elevation overlay -->
        <item name="elevationOverlayEnabled">true</item>

        <!-- Dialog corner radius -->
        <item name="dialogCornerRadius">20dp</item>

        <!-- Shape theming -->
        <item name="shapeAppearanceMediumComponent">@style/KBShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/KBShapeLarge</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.KalavidaraBalaga.Splash" parent="Theme.KalavidaraBalaga">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <!-- ═══════════════════════════════════════
         TYPOGRAPHY STYLES
    ══════════════════════════════════════════ -->
    <style name="KBText.Title" parent="android:Widget.TextView">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="KBText.Subtitle" parent="android:Widget.TextView">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="KBText.Label" parent="android:Widget.TextView">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- ═══════════════════════════════════════
         BUTTON STYLES
    ══════════════════════════════════════════ -->
    <style name="KBButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_gold</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="KBButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">13sp</item>
        <item name="strokeColor">@color/accent</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <!-- ═══════════════════════════════════════
         TEXT INPUT
    ══════════════════════════════════════════ -->
    <style name="KBTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/background_surface</item>
        <item name="boxStrokeColor">@color/primary_light</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- ═══════════════════════════════════════
         ALERT DIALOG
    ══════════════════════════════════════════ -->
    <style name="KBAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@color/background_card</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
        <item name="buttonBarPositiveButtonStyle">@style/KBDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/KBDialogButtonOutline</item>
        <item name="materialAlertDialogTitleTextStyle">@style/KBDialogTitle</item>
        <item name="dialogCornerRadius">20dp</item>
    </style>

    <style name="KBDialogTitle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="KBDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="KBDialogButtonOutline" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ═══════════════════════════════════════
         CARD + SHAPE
    ══════════════════════════════════════════ -->
    <style name="KBCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="KBShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">14dp</item>
    </style>

    <style name="KBShapeLarge" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">20dp</item>
    </style>

</resources>
