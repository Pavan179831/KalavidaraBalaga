rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Troupes collection - public read, no public write
    match /troupes/{troupeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bookings collection - anyone can create, only auth users can read/update
    match /bookings/{bookingId} {
      allow create: if request.resource.data.keys().hasAll([
        'troupeId', 'troupeName', 'organizerName',
        'organizerPhone', 'eventName', 'eventDate',
        'eventLocation', 'status', 'createdAt'
      ]);
      allow read, update, delete: if request.auth != null;
    }
  }
}
